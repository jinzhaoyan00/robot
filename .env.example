# 复制本文件为 .env 并填入实际配置值
# cp .env.example .env

# ──────────────────────────────────────────────────────────────────
# 阿里云 DashScope 配置
# 获取地址：https://dashscope.console.aliyun.com/
# ──────────────────────────────────────────────────────────────────
ALIBABA_API_KEY=your-api-key-here
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIBABA_MODEL=qwen-plus

# ──────────────────────────────────────────────────────────────────
# MCP 服务器配置
# ──────────────────────────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# ──────────────────────────────────────────────────────────────────
# RAG 检索参数
# ──────────────────────────────────────────────────────────────────
# 每路检索返回条数（向量 / BM25 / 图谱各取 RETRIEVE_K 条）
RETRIEVE_K=20
# RRF 融合后送入 LLM 的条数
TOP_N=10
# RRF 平滑系数
RRF_K=60

# ──────────────────────────────────────────────────────────────────
# 索引存储路径（相对于项目根目录，或填写绝对路径）
# ──────────────────────────────────────────────────────────────────
FAISS_DIR=vector_db/faiss
BM25_DIR=vector_db/bm25
KUZU_DIR=vector_db/kuzu_db

# ──────────────────────────────────────────────────────────────────
# 嵌入模型配置（ModelScope Hub 模型 ID）
# ──────────────────────────────────────────────────────────────────
EMBED_MODEL_ID=BAAI/bge-large-zh
